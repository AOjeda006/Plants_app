# =============================================================================
# .env.example — Variables de entorno del backend (TFG Plants App)
# =============================================================================
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el archivo .env al control de versiones.
# =============================================================================

# --- Entorno y servidor ---
NODE_ENV=development
PORT=3000

# --- Base de datos ---
# MongoDB local sin replica set (sin soporte de transacciones):
MONGODB_URI=mongodb://localhost:27017/plants
# MongoDB local con replica set (habilita transacciones):
# MONGODB_URI=mongodb://localhost:27017/plants?replicaSet=rs0

# --- Autenticación JWT ---
JWT_SECRET=cambia_esto_por_una_cadena_larga_y_segura
JWT_EXPIRES_IN=30d

# --- WeatherAPI.com ---
WEATHER_API_KEY=tu_api_key_de_weatherapi
WEATHER_WINDOW_HOURS=48
WEATHER_CACHE_TTL_SECONDS=300
# TFG: activar mock para pruebas locales y evitar consumir cuota gratuita
MOCK_WEATHER_MODE=true

# --- Cloudinary (almacenamiento de imágenes) ---
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# --- Firebase Cloud Messaging (FCM) ---
# Acepta dos formatos (decisión #170 / F7-045):
#   1. Path al archivo JSON descargado desde Firebase Console (modo local):
#      FCM_SERVICE_ACCOUNT_JSON=./firebase-service-account.json
#   2. Contenido del JSON inline en una sola línea (modo Render env vars):
#      FCM_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"…",…}
# Si se deja vacío, el backend opera en modo mock: las notificaciones in-app
# y Socket.IO siguen funcionando, pero no se envían pushes reales al móvil.
FCM_SERVICE_ACCOUNT_JSON=

# --- SMTP (correo electrónico) ---
# OBSOLETO desde la decisión #128 (F6-214): los emails fueron eliminados.
# Estas variables ya no se leen en código y existen solo como rastro
# histórico. La recuperación de contraseña loguea el token en consola.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# --- Credenciales de seed del admin (opcionales) ---
# Si no se definen, el script seed-admin.ts usa los defaults definidos
# en el propio archivo (pensados solo para desarrollo local).
# ADMIN_EMAIL=admin@plants.app
# ADMIN_PASSWORD=cambia_esto_por_una_contrasena_segura

# --- Logging ---
LOG_LEVEL=debug

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# --- Límite de payload ---
PAYLOAD_SIZE_LIMIT=10mb

# --- Métricas (Prometheus, opcional) ---
METRICS_ENABLED=false

# --- Redis (opcional) ---
# Si no se define, se usa InMemoryLockService como fallback
# REDIS_URL=redis://localhost:6379
