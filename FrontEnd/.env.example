# ─── API ─────────────────────────────────────────────────────────────────────
# Default productivo: backend desplegado en Render (decisión #146 / F7-058).
# Para desarrollo con backend en localhost, ejecutar:
#   flutter run --dart-define=USE_LOCAL=true
# (sobrescribe estas URLs y apunta a http://localhost:3000)
API_BASE_URL=https://tfg-86mt.onrender.com
SOCKET_URL=https://tfg-86mt.onrender.com

# ─── Weather ──────────────────────────────────────────────────────────────────
WEATHER_CACHE_TTL_SECONDS=1800
WEATHER_WINDOW_HOURS=24
MOCK_WEATHER_MODE=false

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_UPLOAD_PRESET=tfg_plants

# ─── Firebase / Push ──────────────────────────────────────────────────────────
FCM_ENABLED=false

# ─── General ──────────────────────────────────────────────────────────────────
IS_PRODUCTION=false
DEFAULT_LOCALE=es
